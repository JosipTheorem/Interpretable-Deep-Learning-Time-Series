{
  "output_dir": "results/regime_change",
  "n_runs": 10,
  "combo_limit": null,

  "B_values": [[25, 75], [50, 150], [100, 300], [50, 2000]],
  "losses": ["mse"],

  "ts_length": 20000,
  "window_length": 5,
  "burn_in": 1000,
  "seed": 42,

  "sigma_X1": 0.05,
  "sigma_X2": 0.10,
  "sigma_X3": 0.15,
  "sigma_X4": 0.20,
  "sigma_sets": [
    {
      "name": "low_snr",
      "sigma_X1": 0.05,
      "sigma_X2": 0.10,
      "sigma_X3": 0.15,
      "sigma_X4": 0.20
    },
    {
      "name": "high_snr",
      "sigma_X1": 1.00,
      "sigma_X2": 0.05,
      "sigma_X3": 0.05,
      "sigma_X4": 1.00
    }
  ],

  "learning_rate": 0.001,
  "scheduler_patience": 5,
  "early_stopping_modifier": 2,
  "epochs": 100,
  "batch_size": 64,
  "train_ratio": 0.6,
  "val_ratio": 0.2,
  "temperature": 1.0,
  "order": [1, 1],

  "alpha_threshold": 0.04,
  "stability_c": 1.95,

  "classification_test_size": 0.3,
  "classification_gap": 5,
  "classification_models": ["logistic", "tree"],

  "huber_delta": 0.1,
  "smooth_l1_beta": 0.1,

  "device": "auto"
}
