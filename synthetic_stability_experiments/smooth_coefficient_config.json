{
  "output_dir": "results/smooth_coefficient",
  "n_runs": 10,
  "combo_limit": null,

  "case_types": ["sinusoidal", "monotonic_drift", "gaussian_pulse", "zero_crossing_sine"],
  "sinusoidal_cases": [
    {"a0": 0.50, "a1": 0.25, "P": 500, "phi": 0.0, "name": "baseline"},
    {"a0": 0.50, "a1": 0.10, "P": 500, "phi": 0.0, "name": "low_amplitude"},
    {"a0": 0.50, "a1": 0.40, "P": 500, "phi": 0.0, "name": "high_amplitude"},
    {"a0": 0.50, "a1": 0.25, "P": 100, "phi": 0.0, "name": "fast_period"},
    {"a0": 0.50, "a1": 0.25, "P": 2000, "phi": 0.0, "name": "slow_period"},
    {"a0": 0.50, "a1": 0.25, "P": 500, "phi": 1.5707963267948966, "name": "phase_pi_over_2"}
  ],
  "monotonic_drift_cases": [
    {"a_min": 0.10, "a_max": 0.90, "name": "default"}
  ],
  "gaussian_pulse_cases": [
    {"a0": 0.10, "a1": 0.75, "t0_frac": 0.60, "s_frac": 0.30, "name": "wide_mid"},
    {"a0": 0.10, "a1": 0.75, "t0_frac": 0.50, "s_frac": 0.15, "name": "train_peak"},
    {"a0": 0.10, "a1": 0.75, "t0_frac": 0.80, "s_frac": 0.15, "name": "test_border_peak"}
  ],
  "zero_crossing_sine_cases": [
    {"a1": 0.60, "P": 500, "name": "default"}
  ],

  "sigma_sets": [
    {
      "name": "low_snr",
      "sigma_X1": 0.05,
      "sigma_X2": 0.10,
      "sigma_X3": 0.15,
      "sigma_X4": 0.20
    },
    {
      "name": "high_snr",
      "sigma_X1": 1.00,
      "sigma_X2": 0.05,
      "sigma_X3": 0.05,
      "sigma_X4": 0.10
    }
  ],
  "losses": ["mse"],
  "var_windows": [20, 100],

  "ts_length": 20000,
  "window_length": 5,
  "burn_in": 1000,
  "seed": 42,

  "learning_rate": 0.001,
  "scheduler_patience": 5,
  "early_stopping_modifier": 2,
  "epochs": 100,
  "batch_size": 64,
  "train_ratio": 0.6,
  "val_ratio": 0.2,
  "temperature": 1.0,
  "order": [1, 1],

  "alpha_threshold": 0.04,
  "stability_c": 1.95,

  "huber_delta": 0.1,
  "smooth_l1_beta": 0.1,

  "device": "auto"
}
